{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@marimail/db": ["packages/db/src/index.ts"],
      "@marimail/types": ["packages/types/src/index.ts"],
      "@marimail/utils": ["packages/utils/src/index.ts"],
      "@marimail/email": ["packages/email/src/index.ts"]
    }
  }
}
