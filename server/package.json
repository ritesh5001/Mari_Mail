{
  "name": "@marimail/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm turbo run build --filter=@marimail/db --filter=@marimail/email --filter=@marimail/types --filter=@marimail/utils && tsc",
    "start": "node dist/server/src/index.js",
    "worker": "tsx src/worker.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1061.0",
    "@azure/msal-node": "^2.16.2",
    "@marimail/db": "workspace:*",
    "@marimail/email": "workspace:*",
    "@marimail/types": "workspace:*",
    "@marimail/utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.28.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "socket.io": "^4.8.1",
    "stripe": "^22.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^6.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
