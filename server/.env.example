# ─────────────────────────────────────────────
# MariMail — Server (Express on Render)
# Copy to .env for local development.
# All vars marked [Render] must be set in the
# Render service → Environment section.
# ─────────────────────────────────────────────

# ── Server ───────────────────────────────────
PORT=3001
START_WORKERS=true   # set false to disable BullMQ workers (useful for web-only dynos)

# ── URLs ─────────────────────────────────────
APP_URL=http://localhost:3000              # [Render] https://mail.maribiz.ai
API_URL=http://localhost:3001              # [Render] https://<render-service>.onrender.com

# Comma-separated origins allowed for CORS.
ALLOWED_ORIGINS=http://localhost:3000,https://mail.maribiz.ai  # [Render] keep production URL

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marimail  # [Render] use Neon/production URL

# ── Redis (optional — falls back to in-memory) ──
# Required for BullMQ job queues (campaign scheduler, warmup, analytics cron).
# Omit or set to a localhost URL to use the in-memory fallback (dev/testing only).
REDIS_URL=redis://localhost:6379           # [Render] set to Redis Cloud / Upstash URL

# ── Auth secrets ─────────────────────────────
# JWT_ACCESS_SECRET  — signs short-lived access tokens (15 min)
# JWT_REFRESH_SECRET — signs long-lived refresh tokens (7 days)
# ENCRYPTION_KEY     — 64-char hex key used to encrypt stored OAuth tokens
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

# ── Email sending (Resend) ───────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=MariMail <no-reply@mail.maribiz.ai>

# ── Google OAuth (Gmail inbox integration) ───
# Same credentials used by the client for user sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth (Outlook inbox integration) ──
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# ── Stripe (billing) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Inbound email (reply tracking) ───────────
INBOUND_EMAIL_DOMAIN=inbound.marimail.local   # [Render] set to your MX-routed subdomain
