{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@marimail/db": ["../packages/db/src/index.ts"],
      "@marimail/types": ["../packages/types/src/index.ts"],
      "@marimail/utils": ["../packages/utils/src/index.ts"],
      "@marimail/email": ["../packages/email/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
