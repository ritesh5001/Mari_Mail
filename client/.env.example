# ─────────────────────────────────────────────
# MariMail — Client (Next.js on Vercel)
# Copy to .env for local development.
# All vars marked [Vercel] must also be set in
# Vercel project → Settings → Environment Variables.
# ─────────────────────────────────────────────

# ── Backend URL ──────────────────────────────
# Browser-side fetches use /backend rewrite (set below).
# Server Components (Vercel runtime) need the direct backend URL.
NEXT_PUBLIC_API_URL=https://marimail-5v22.onrender.com   # [Vercel] set to https://<render-service>.onrender.com
API_URL=https://marimail-5v22.onrender.com              # [Vercel] same value as NEXT_PUBLIC_API_URL

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marimail  # [Vercel] use Neon/production URL
