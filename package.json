{
  "name": "marimail",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev --filter=@marimail/client --filter=@marimail/server",
    "dev:client": "pnpm --filter @marimail/client dev",
    "dev:server": "pnpm --filter @marimail/server dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @marimail/db db:generate",
    "db:migrate": "pnpm --filter @marimail/db db:migrate",
    "db:deploy": "pnpm --filter @marimail/db db:deploy",
    "db:seed": "pnpm --filter @marimail/db db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.17.6",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
